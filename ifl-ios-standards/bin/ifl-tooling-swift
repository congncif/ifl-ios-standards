#!/bin/bash
set -euo pipefail
umask 077
export LC_ALL=C

invalid_input() {
    echo "ifl-tooling-swift: $1" >&2
    exit 2
}

blocked_environment() {
    echo "ifl-tooling-swift: $1" >&2
    exit 3
}

reject_protected_arguments() {
    for ARGUMENT in "$@"; do
        case "$ARGUMENT" in
            --package-path|--package-path=*|\
            --scratch-path|--scratch-path=*|\
            --build-path|--build-path=*|\
            --cache-path|--cache-path=*|\
            --config-path|--config-path=*|\
            --security-path|--security-path=*|\
            --swift-sdks-path|--swift-sdks-path=*|\
            --toolset|--toolset=*|\
            --toolchain|--toolchain=*|\
            --pkg-config-path|--pkg-config-path=*|\
            --sdk|--sdk=*|\
            --swift-sdk|--swift-sdk=*|\
            --triple|--triple=*|\
            --disable-sandbox|\
            --netrc|--enable-netrc|--netrc-file|--netrc-file=*|\
            --resolver-fingerprint-checking|--resolver-fingerprint-checking=*|\
            --resolver-signing-entity-checking|--resolver-signing-entity-checking=*|\
            --disable-signature-validation|\
            --default-registry-url|--default-registry-url=*|\
            -Xcc|-Xcc=*|-Xswiftc|-Xswiftc=*|-Xlinker|-Xlinker=*)
                invalid_input "caller cannot override launcher-owned path, toolchain, or security options"
                ;;
        esac
    done
}

join_path() {
    if [ "$1" = "/" ]; then
        JOINED_PATH="/$2"
    else
        JOINED_PATH="$1/$2"
    fi
}

case "${1:-}" in
    run|test|build|package)
        SUBCOMMAND="$1"
        shift
        ;;
    *)
        invalid_input "expected one of run|test|build|package"
        ;;
esac

reject_protected_arguments "$@"

SCRIPT_DIR="$(cd -P "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PLUGIN_ROOT="$(cd -P "$SCRIPT_DIR/.." && pwd)"
PACKAGE_ROOT="$(cd -P "$PLUGIN_ROOT/tools/ifl-tooling" && pwd)"
VERSION_FILE="$PLUGIN_ROOT/VERSION"

[ -f "$VERSION_FILE" ] && [ ! -L "$VERSION_FILE" ] || invalid_input "VERSION must be a regular non-symlink file"
if ! IFS= read -r PLUGIN_VERSION < "$VERSION_FILE"; then
    invalid_input "VERSION must end with exactly one newline"
fi
VERSION_BYTE_COUNT="$(/usr/bin/wc -c < "$VERSION_FILE" | /usr/bin/tr -d '[:space:]')"
case "$VERSION_BYTE_COUNT" in
    ''|*[!0-9]*) invalid_input "VERSION byte count is invalid" ;;
esac
EXPECTED_VERSION_BYTES=$((${#PLUGIN_VERSION} + 1))
[ "$VERSION_BYTE_COUNT" -eq "$EXPECTED_VERSION_BYTES" ] || invalid_input "VERSION must contain exactly one newline-terminated value"

SEMVER_PATTERN='^(0|[1-9][0-9]*)\.(0|[1-9][0-9]*)\.(0|[1-9][0-9]*)(-([0-9A-Za-z-]+(\.[0-9A-Za-z-]+)*))?(\+([0-9A-Za-z-]+(\.[0-9A-Za-z-]+)*))?$'
[[ "$PLUGIN_VERSION" =~ $SEMVER_PATTERN ]] || invalid_input "VERSION is not canonical SemVer"
CORE_AND_PRERELEASE="${PLUGIN_VERSION%%+*}"
if [[ "$CORE_AND_PRERELEASE" == *-* ]]; then
    PRERELEASE="${CORE_AND_PRERELEASE#*-}"
    OLD_IFS="$IFS"
    IFS='.'
    read -r -a PRERELEASE_COMPONENTS <<< "$PRERELEASE"
    IFS="$OLD_IFS"
    for IDENTIFIER in "${PRERELEASE_COMPONENTS[@]}"; do
        if [[ "$IDENTIFIER" =~ ^[0-9]+$ ]] && [[ "$IDENTIFIER" =~ ^0[0-9]+$ ]]; then
            invalid_input "numeric prerelease identifiers cannot contain a leading zero"
        fi
    done
fi

WORKSPACE_HASH_LINE="$(printf '%s' "$PACKAGE_ROOT" | /usr/bin/shasum -a 256)" || blocked_environment "cannot derive workspace key"
WORKSPACE_KEY="${WORKSPACE_HASH_LINE%% *}"
[[ "$WORKSPACE_KEY" =~ ^[0-9a-f]{64}$ ]] || blocked_environment "workspace key is not a lowercase SHA-256"

RAW_SCRATCH_BASE="${IFL_SWIFTPM_SCRATCH_ROOT:-${TMPDIR:-/tmp}/ifl-ios-standards-swiftpm}"
case "$RAW_SCRATCH_BASE" in
    *$'\n'*) invalid_input "scratch root contains a newline" ;;
esac
RAW_SCRATCH_BASE="$(printf '%s\n' "$RAW_SCRATCH_BASE" | /usr/bin/sed 's://*:/:g')"
if [[ "$RAW_SCRATCH_BASE" != /* ]]; then
    CURRENT_PHYSICAL="$(pwd -P)"
    RAW_SCRATCH_BASE="$CURRENT_PHYSICAL/$RAW_SCRATCH_BASE"
fi

OLD_IFS="$IFS"
IFS='/'
read -r -a SCRATCH_COMPONENTS <<< "$RAW_SCRATCH_BASE"
IFS="$OLD_IFS"
for COMPONENT in "${SCRATCH_COMPONENTS[@]}"; do
    case "$COMPONENT" in
        '' ) ;;
        '.'|'..') invalid_input "scratch root contains a traversal component" ;;
    esac
done

CURSOR="$RAW_SCRATCH_BASE"
MISSING_COMPONENTS=()
MISSING_COMPONENT_COUNT=0
while [ ! -e "$CURSOR" ] && [ ! -L "$CURSOR" ]; do
    COMPONENT="${CURSOR##*/}"
    [ -n "$COMPONENT" ] || invalid_input "scratch root cannot be resolved"
    MISSING_COMPONENTS[$MISSING_COMPONENT_COUNT]="$COMPONENT"
    MISSING_COMPONENT_COUNT=$((MISSING_COMPONENT_COUNT + 1))
    CURSOR="${CURSOR%/*}"
    [ -n "$CURSOR" ] || CURSOR="/"
done
[ -d "$CURSOR" ] || invalid_input "scratch root ancestor is not a directory"
PHYSICAL_ANCESTOR="$(cd -P "$CURSOR" && pwd)" || invalid_input "scratch root ancestor cannot be resolved"

PROSPECTIVE_BASE="$PHYSICAL_ANCESTOR"
for ((INDEX = MISSING_COMPONENT_COUNT - 1; INDEX >= 0; INDEX--)); do
    COMPONENT="${MISSING_COMPONENTS[$INDEX]}"
    join_path "$PROSPECTIVE_BASE" "$COMPONENT"
    PROSPECTIVE_BASE="$JOINED_PATH"
done
case "$PROSPECTIVE_BASE/" in
    "$PLUGIN_ROOT/"*) invalid_input "scratch root must be outside the plugin" ;;
esac

PHYSICAL_BASE="$PHYSICAL_ANCESTOR"
for ((INDEX = MISSING_COMPONENT_COUNT - 1; INDEX >= 0; INDEX--)); do
    COMPONENT="${MISSING_COMPONENTS[$INDEX]}"
    join_path "$PHYSICAL_BASE" "$COMPONENT"
    TARGET="$JOINED_PATH"
    [ ! -L "$TARGET" ] || invalid_input "scratch root component is a symlink"
    if [ ! -e "$TARGET" ]; then
        if ! /bin/mkdir -m 700 "$TARGET"; then
            if [ -L "$TARGET" ] || [ ! -d "$TARGET" ]; then
                blocked_environment "cannot create scratch root"
            fi
        fi
    fi
    [ -d "$TARGET" ] && [ ! -L "$TARGET" ] || invalid_input "scratch root component is not a physical directory"
    RESOLVED_TARGET="$(cd -P "$TARGET" && pwd)" || invalid_input "scratch root component cannot be resolved"
    [ "$RESOLVED_TARGET" = "$TARGET" ] || invalid_input "scratch root component changed identity"
    PHYSICAL_BASE="$RESOLVED_TARGET"
done

case "$PHYSICAL_BASE/" in
    "$PLUGIN_ROOT/"*) invalid_input "physical scratch root must be outside the plugin" ;;
esac

ensure_controlled_directory() {
    CONTROLLED_PARENT="$1"
    CONTROLLED_NAME="$2"
    join_path "$CONTROLLED_PARENT" "$CONTROLLED_NAME"
    CONTROLLED_TARGET="$JOINED_PATH"
    [ ! -L "$CONTROLLED_TARGET" ] || invalid_input "controlled scratch component is a symlink"
    if [ ! -e "$CONTROLLED_TARGET" ]; then
        if ! /bin/mkdir -m 700 "$CONTROLLED_TARGET"; then
            if [ -L "$CONTROLLED_TARGET" ] || [ ! -d "$CONTROLLED_TARGET" ]; then
                blocked_environment "cannot create controlled scratch component"
            fi
        fi
    fi
    [ -d "$CONTROLLED_TARGET" ] && [ ! -L "$CONTROLLED_TARGET" ] || invalid_input "controlled scratch component is not a physical directory"
    CONTROLLED_RESULT="$(cd -P "$CONTROLLED_TARGET" && pwd)" || invalid_input "controlled scratch component cannot be resolved"
    [ "$CONTROLLED_RESULT" = "$CONTROLLED_TARGET" ] || invalid_input "controlled scratch component changed identity"
    CONTROLLED_METADATA="$(/usr/bin/stat -f '%u %Lp' "$CONTROLLED_RESULT")" || blocked_environment "cannot inspect controlled scratch component"
    CONTROLLED_OWNER="${CONTROLLED_METADATA%% *}"
    CONTROLLED_MODE="${CONTROLLED_METADATA##* }"
    case "$CONTROLLED_OWNER:$CONTROLLED_MODE" in
        *[!0-9:]*|:*|*:) blocked_environment "controlled scratch metadata is invalid" ;;
    esac
    [ "$CONTROLLED_OWNER" = "$EFFECTIVE_UID" ] || invalid_input "controlled scratch component has an unexpected owner"
    [ "$((8#$CONTROLLED_MODE & 077))" -eq 0 ] || invalid_input "controlled scratch component is not private"
}

EFFECTIVE_UID="$(/usr/bin/id -u)" || blocked_environment "cannot determine effective user"
ensure_controlled_directory "$PHYSICAL_BASE" "$WORKSPACE_KEY"
WORKSPACE_ROOT="$CONTROLLED_RESULT"
FILESYSTEM_NAME_MAX="$(/usr/bin/getconf NAME_MAX "$WORKSPACE_ROOT")" || blocked_environment "cannot determine filesystem NAME_MAX"
case "$FILESYSTEM_NAME_MAX" in
    ''|*[!0-9]*) blocked_environment "filesystem NAME_MAX is invalid" ;;
esac
[ "${#PLUGIN_VERSION}" -le "$FILESYSTEM_NAME_MAX" ] || invalid_input "VERSION exceeds filesystem NAME_MAX"
ensure_controlled_directory "$WORKSPACE_ROOT" "$PLUGIN_VERSION"
SCRATCH="$CONTROLLED_RESULT"

if [ "${_IFL_TOOLING_TESTING:-0}" = "1" ] && [ -n "${_IFL_TOOLING_TEST_GATE_DIR:-}" ]; then
    TEST_GATE_DIR="$_IFL_TOOLING_TEST_GATE_DIR"
    [ -d "$TEST_GATE_DIR" ] && [ ! -L "$TEST_GATE_DIR" ] || invalid_input "test gate must be a physical directory"
    TEST_GATE_PHYSICAL="$(cd -P "$TEST_GATE_DIR" && pwd)" || invalid_input "test gate cannot be resolved"
    case "$TEST_GATE_PHYSICAL/" in
        "$PLUGIN_ROOT/"*) invalid_input "test gate must be outside the plugin" ;;
    esac
    : > "$TEST_GATE_PHYSICAL/ready"
    TEST_GATE_DEADLINE=$((SECONDS + 15))
    while [ ! -e "$TEST_GATE_PHYSICAL/release" ]; do
        [ "$SECONDS" -lt "$TEST_GATE_DEADLINE" ] || blocked_environment "test gate timed out"
        /bin/sleep 0.05
    done
fi

[ ! -L "$WORKSPACE_ROOT" ] && [ ! -L "$SCRATCH" ] || invalid_input "controlled scratch component was replaced by a symlink"
FINAL_WORKSPACE_ROOT="$(cd -P "$WORKSPACE_ROOT" && pwd)" || invalid_input "workspace scratch cannot be re-resolved"
FINAL_SCRATCH="$(cd -P "$SCRATCH" && pwd)" || invalid_input "version scratch cannot be re-resolved"
[ "$FINAL_WORKSPACE_ROOT" = "$PHYSICAL_BASE/$WORKSPACE_KEY" ] || invalid_input "workspace scratch changed physical identity"
[ "$FINAL_SCRATCH" = "$FINAL_WORKSPACE_ROOT/$PLUGIN_VERSION" ] || invalid_input "version scratch changed physical identity"
case "$FINAL_SCRATCH/" in
    "$PHYSICAL_BASE/"*) ;;
    *) invalid_input "final scratch escaped its physical base" ;;
esac
case "$FINAL_SCRATCH/" in
    "$PLUGIN_ROOT/"*) invalid_input "final scratch resolved inside the plugin" ;;
esac

ensure_controlled_directory "$FINAL_SCRATCH" "swiftpm-cache"
SWIFTPM_CACHE_PATH="$CONTROLLED_RESULT"
ensure_controlled_directory "$FINAL_SCRATCH" "swiftpm-configuration"
SWIFTPM_CONFIG_PATH="$CONTROLLED_RESULT"
ensure_controlled_directory "$FINAL_SCRATCH" "swiftpm-security"
SWIFTPM_SECURITY_PATH="$CONTROLLED_RESULT"
ensure_controlled_directory "$FINAL_SCRATCH" "module-cache"
MODULE_CACHE_PATH="$CONTROLLED_RESULT"

unset XDG_CACHE_HOME
export CLANG_MODULE_CACHE_PATH="$MODULE_CACHE_PATH"
export SWIFTPM_MODULECACHE_OVERRIDE="$MODULE_CACHE_PATH"
export _IFL_TOOLING_PRODUCT_VERSION="$PLUGIN_VERSION"
exec /usr/bin/xcrun swift "$SUBCOMMAND" \
    --package-path "$PACKAGE_ROOT" \
    --scratch-path "$FINAL_SCRATCH" \
    --cache-path "$SWIFTPM_CACHE_PATH" \
    --config-path "$SWIFTPM_CONFIG_PATH" \
    --security-path "$SWIFTPM_SECURITY_PATH" \
    "$@"
