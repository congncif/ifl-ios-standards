#!/usr/bin/env bash
set -euo pipefail

# ifl-new-module <ModuleName> [--root=PATH] [--module-root=PATH] [--dry-run]
#
# Creates only the Boardy module source boundary:
#   IO/{ModuleName}ServiceMap.swift
#   Sources/Plugins/{ModuleName}PluginsServiceMap.swift
#   Sources/Plugins/{ModuleName}ModulePlugin.swift
#
# Build-system files and tests stay owned by the consuming repository. The command never guesses
# organization-specific Bazel labels, package versions, deployment targets, licenses, or vendors.
# It refuses to overwrite an existing module directory.

usage() { sed -n '4,15p' "$0"; }

[ $# -ge 1 ] || { usage; exit 64; }

MODULE="$1"
shift
ROOT="$PWD"
MROOT=""
DRY=0

case "$MODULE" in
  -h|--help) usage; exit 0 ;;
esac

if ! [[ "$MODULE" =~ ^[A-Z][A-Za-z0-9]*$ ]]; then
  echo "ifl-new-module: module name must match [A-Z][A-Za-z0-9]* (got '$MODULE')" >&2
  exit 64
fi

for argument in "$@"; do
  case "$argument" in
    --root=*)        ROOT="${argument#--root=}" ;;
    --module-root=*) MROOT="${argument#--module-root=}" ;;
    --dry-run)       DRY=1 ;;
    -h|--help)       usage; exit 0 ;;
    *) echo "ifl-new-module: unknown argument '$argument'" >&2; exit 64 ;;
  esac
done

[ -d "$ROOT" ] || { echo "ifl-new-module: root '$ROOT' is not a directory" >&2; exit 65; }
ROOT="$(cd "$ROOT" && pwd)"

module_root_from() {
  local file="$1"
  [ -f "$file" ] || return 0
  grep -E '^\|[[:space:]]*Module root[[:space:]]*\|' "$file" \
    | head -1 \
    | sed -E 's/.*\|[[:space:]]*`?([^`|]+)`?[[:space:]]*\|.*/\1/' \
    | sed -E 's/[[:space:]]+$//' \
    || true
}

resolve_module_root() {
  if [ -n "$MROOT" ]; then
    printf '%s\n' "$MROOT"
    return
  fi

  local file value
  for file in \
    "$ROOT/CLAUDE.md" \
    "$ROOT/AGENTS.md" \
    "$ROOT/.claude/project/PROJECT_CONFIG.md"; do
    value="$(module_root_from "$file")"
    if [ -n "$value" ] && [[ "$value" != \{* ]]; then
      printf '%s\n' "${value%/}"
      return
    fi
  done

  echo "ifl-new-module: module root is not configured; pass --module-root=PATH or set the Module root row in CLAUDE.md/AGENTS.md" >&2
  exit 64
}

MROOT="$(resolve_module_root)"
if ! [[ "$MROOT" =~ ^[A-Za-z0-9._/-]+$ ]]; then
  echo "ifl-new-module: module root must be a repository-relative path token (got '$MROOT')" >&2
  exit 64
fi
case "$MROOT" in
  ..|../*|*/..|*/../*|./*|*/.|*/./*) echo "ifl-new-module: module root must not contain traversal components (got '$MROOT')" >&2; exit 64 ;;
esac
case "$MROOT" in
  /*) echo "ifl-new-module: module root must be repository-relative (got '$MROOT')" >&2; exit 64 ;;
esac

MDIR="$ROOT/$MROOT/$MODULE"
if [ -e "$MDIR" ]; then
  echo "ifl-new-module: destination exists — $MDIR" >&2
  exit 1
fi

CREATED_ON="$(date +%Y-%m-%d)"

emit() {
  local path="$1"
  local content="$2"
  if [ "$DRY" = 1 ]; then
    echo "DRY  write $path  (${#content} bytes)"
    return
  fi
  mkdir -p "$(dirname "$path")"
  printf '%s\n' "$content" > "$path"
  echo "  WRITE  ${path#$ROOT/}"
}

echo "ifl-new-module — scaffolding Boardy source boundary for $MODULE"
echo "  root:        $ROOT"
echo "  module-root: $MROOT"
echo "  destination: $MDIR"
echo "  dry:         $DRY"
echo

emit "$MDIR/IO/${MODULE}ServiceMap.swift" "// Created on $CREATED_ON by ifl-new-module

import Boardy

public final class ${MODULE}ServiceMap: ServiceMap {}

public extension ServiceMap {
    var mod${MODULE}: ${MODULE}ServiceMap { link() }
}"

emit "$MDIR/Sources/Plugins/${MODULE}PluginsServiceMap.swift" "// Created on $CREATED_ON by ifl-new-module

import Boardy

final class ${MODULE}PluginsServiceMap: ServiceMap {}

extension ServiceMap {
    var mod${MODULE}Plugins: ${MODULE}PluginsServiceMap { link() }
}"

emit "$MDIR/Sources/Plugins/${MODULE}ModulePlugin.swift" "// Created on $CREATED_ON by ifl-new-module

import Boardy
import $MODULE

// Add ModuleBuilderPlugin after the first public entry Board exists. Its ServiceType, identifier,
// build(with:sharedComponent:internalContinuousProducer:), and registrations must be derived from
// real Board contracts; the scaffolder does not invent a fake entry or silently green behavior."

if [ "$DRY" != 1 ]; then
  echo
  echo "Done. Next steps:"
  echo "  1. Add $MROOT/$MODULE to the consuming repository's build/package configuration."
  echo "  2. Add a board: ifl-new-board $MODULE <Board> <ui|swiftui|viewless|flow|blocktask> --root=$ROOT"
  echo "  3. Complete ${MODULE}ModulePlugin from the canonical plugin spec using real Board IDs."
  echo "  4. Add executable tests only for real behavior, then run one repository-owned signal."
fi
