#!/usr/bin/env bash
set -euo pipefail

# ifl-init — seed project bindings and Codex specialist-agent configuration.
#
# Copies the portable-claude starter to the repo root and pre-fills only values supported by
# unambiguous repository evidence. Governed values it cannot prove (including base branch, module
# root, destinations, and build/test commands) stay as {Placeholders} for the
# `/ifl-ios-standards:init` skill or a human owner to resolve.
#
# Usage:
#   ifl-init [--root=PATH] [--codex-agents-only] [--force] [--dry-run]
#
# Flags:
#   --root=PATH          target repo root (default: $PWD)
#   --codex-agents-only  install/refresh only the project-scoped Codex agent files
#   --force              overwrite matching generated files
#   --dry-run            print what would happen; write nothing
#
# Refuses to overwrite matching generated files unless --force.

ROOT="$PWD"
FORCE=0
DRY=0
CODEX_AGENTS_ONLY=0

for a in "$@"; do
  case "$a" in
    --root=*)   ROOT="${a#--root=}" ;;
    --codex-agents-only) CODEX_AGENTS_ONLY=1 ;;
    --force)    FORCE=1 ;;
    --dry-run)  DRY=1 ;;
    -h|--help)  sed -n '4,21p' "$0"; exit 0 ;;
    *) echo "ifl-init: unknown arg '$a'" >&2; exit 64 ;;
  esac
done

[ -d "$ROOT" ] || { echo "ifl-init: root '$ROOT' not a directory" >&2; exit 65; }
ROOT="$(cd "$ROOT" && pwd)"

# Resolve templates relative to this script (works on PATH + standalone + in plugin cache).
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PLUGIN_ROOT="${CLAUDE_PLUGIN_ROOT:-$(cd "$SCRIPT_DIR/.." && pwd)}"
TEMPLATE_DIR="$PLUGIN_ROOT/standards/templates/portable-claude"
CODEX_AGENT_TEMPLATE_DIR="$PLUGIN_ROOT/standards/templates/codex-agents"
SRC="$TEMPLATE_DIR/CLAUDE.md"
[ -f "$SRC" ] || { echo "ifl-init: starter template not found at $SRC" >&2; exit 65; }
[ -d "$CODEX_AGENT_TEMPLATE_DIR" ] || {
  echo "ifl-init: Codex agent templates not found at $CODEX_AGENT_TEMPLATE_DIR" >&2
  exit 65
}

CODEX_AGENT_SOURCES=("$CODEX_AGENT_TEMPLATE_DIR"/*.toml)
[ -e "${CODEX_AGENT_SOURCES[0]}" ] || {
  echo "ifl-init: no Codex agent templates found at $CODEX_AGENT_TEMPLATE_DIR" >&2
  exit 65
}

DST_CLAUDE="$ROOT/CLAUDE.md"
DST_AGENTS="$ROOT/AGENTS.md"
DST_CODEX_AGENT_DIR="$ROOT/.codex/agents"

check_codex_agent_conflicts() {
  local src dst
  [ "$FORCE" = 1 ] && return 0
  for src in "${CODEX_AGENT_SOURCES[@]}"; do
    dst="$DST_CODEX_AGENT_DIR/$(basename "$src")"
    [ -e "$dst" ] && {
      echo "ifl-init: ${dst#$ROOT/} exists — pass --force to overwrite" >&2
      exit 1
    }
  done
  return 0
}

write_codex_agents() {
  local src
  mkdir -p "$DST_CODEX_AGENT_DIR"
  for src in "${CODEX_AGENT_SOURCES[@]}"; do
    cp "$src" "$DST_CODEX_AGENT_DIR/$(basename "$src")"
  done
  echo "  WROTE  ${#CODEX_AGENT_SOURCES[@]} project-scoped Codex agents under .codex/agents/"
}

check_codex_agent_conflicts

if [ "$CODEX_AGENTS_ONLY" = 1 ]; then
  echo "ifl-init — seeding Codex specialist agents"
  echo "  root:        $ROOT"
  echo "  templates:   $CODEX_AGENT_TEMPLATE_DIR"
  echo "  dry:         $DRY"
  echo
  if [ "$DRY" = 1 ]; then
    echo "DRY  would write ${#CODEX_AGENT_SOURCES[@]} files under $DST_CODEX_AGENT_DIR"
  else
    write_codex_agents
  fi
  exit 0
fi

if [ "$FORCE" != 1 ]; then
  for f in "$DST_CLAUDE" "$DST_AGENTS"; do
    [ -e "$f" ] && { echo "ifl-init: ${f#$ROOT/} exists — pass --force to overwrite" >&2; exit 1; }
  done
fi

# ── Detect bindings from the repo ────────────────────────────────────────────

PROJECT_NAME="$(basename "$ROOT")"
GIT_REMOTE="{GitRemote}"
GIT_URL="{GitRemoteURL}"
BASE_BRANCH="{BaseBranch}"

# A single configured remote is observable. Its remote HEAD is acceptable base-branch evidence;
# the current working branch is not.
REMOTE_NAMES="$(git -C "$ROOT" remote 2>/dev/null || true)"
REMOTE_COUNT="$(printf '%s\n' "$REMOTE_NAMES" | sed '/^$/d' | wc -l | tr -d ' ')"
if [ "$REMOTE_COUNT" = 1 ]; then
  GIT_REMOTE="$(printf '%s\n' "$REMOTE_NAMES" | sed -n '1p')"
  DETECTED_GIT_URL="$(git -C "$ROOT" remote get-url "$GIT_REMOTE" 2>/dev/null || true)"
  [ -n "$DETECTED_GIT_URL" ] && GIT_URL="$DETECTED_GIT_URL"

  REMOTE_HEAD="$(git -C "$ROOT" symbolic-ref --quiet --short "refs/remotes/$GIT_REMOTE/HEAD" 2>/dev/null || true)"
  case "$REMOTE_HEAD" in
    "$GIT_REMOTE"/*) BASE_BRANCH="${REMOTE_HEAD#"$GIT_REMOTE"/}" ;;
  esac
fi

# first_glob PATTERN  — echo the first matching path, or empty (never fails under set -e/pipefail).
first_glob() {
  local p
  for p in $1; do [ -e "$p" ] && { printf '%s\n' "$p"; return 0; }; done
  return 0
}

# Build/package system + integration file + module root
BUILD_SYSTEM="{BuildSystem}"; BUILD_INTEGRATION="{BuildIntegration}"; MODULE_ROOT="{ModuleRoot}"
HAS_BAZEL=0; HAS_COCOAPODS=0; HAS_SWIFTPM=0
[ -f "$ROOT/BUILD" ] || [ -f "$ROOT/BUILD.bazel" ] || [ -f "$ROOT/MODULE.bazel" ] || \
  [ -f "$ROOT/WORKSPACE" ] || [ -f "$ROOT/WORKSPACE.bazel" ] || [ -f "$ROOT/.bazelrc" ] || \
  [ -n "$(first_glob "$ROOT/*.bazelrc")" ] && HAS_BAZEL=1
[ -f "$ROOT/Podfile" ] || [ -n "$(first_glob "$ROOT/*.podspec")" ] && HAS_COCOAPODS=1
[ -f "$ROOT/Package.swift" ] && HAS_SWIFTPM=1

SYSTEM_COUNT=$((HAS_BAZEL + HAS_COCOAPODS + HAS_SWIFTPM))
if [ "$SYSTEM_COUNT" = 1 ] && [ "$HAS_BAZEL" = 1 ]; then
  BUILD_SYSTEM="Bazel"
  if [ -f "$ROOT/BUILD.bazel" ]; then
    BUILD_INTEGRATION="BUILD.bazel"
  elif [ -f "$ROOT/BUILD" ]; then
    BUILD_INTEGRATION="BUILD"
  elif [ -f "$ROOT/MODULE.bazel" ]; then
    BUILD_INTEGRATION="MODULE.bazel"
  elif [ -f "$ROOT/WORKSPACE.bazel" ]; then
    BUILD_INTEGRATION="WORKSPACE.bazel"
  elif [ -f "$ROOT/WORKSPACE" ]; then
    BUILD_INTEGRATION="WORKSPACE"
  elif [ -f "$ROOT/.bazelrc" ]; then
    BUILD_INTEGRATION=".bazelrc"
  else
    BAZELRC="$(first_glob "$ROOT/*.bazelrc")"
    BUILD_INTEGRATION="$(basename "$BAZELRC")"
  fi
elif [ "$SYSTEM_COUNT" = 1 ] && [ "$HAS_COCOAPODS" = 1 ]; then
  BUILD_SYSTEM="CocoaPods"
  if [ -f "$ROOT/Podfile" ] && [ -n "$(first_glob "$ROOT/*.podspec")" ]; then
    BUILD_INTEGRATION="Podfile + *.podspec"
  elif [ -f "$ROOT/Podfile" ]; then
    BUILD_INTEGRATION="Podfile"
  else
    BUILD_INTEGRATION="*.podspec"
  fi
elif [ "$SYSTEM_COUNT" = 1 ] && [ "$HAS_SWIFTPM" = 1 ]; then
  BUILD_SYSTEM="Swift Package Manager"; BUILD_INTEGRATION="Package.swift"
fi

# Workspace / xcodeproj: fill only when the repository has one unambiguous candidate.
single_glob() {
  local pattern="$1" p found="" count=0
  while IFS= read -r p; do
    [ -e "$p" ] || continue
    found="$p"
    count=$((count + 1))
  done < <(compgen -G "$pattern" || true)
  [ "$count" = 1 ] && printf '%s\n' "$found"
  return 0
}

WORKSPACE="{Workspace}"
WS="$(single_glob "$ROOT/*.xcworkspace")"
WS_ANY="$(first_glob "$ROOT/*.xcworkspace")"
if [ -n "$WS" ]; then
  WORKSPACE="$(basename "$WS")"
elif [ -z "$WS_ANY" ]; then
  PROJ="$(single_glob "$ROOT/*.xcodeproj")"
  [ -n "$PROJ" ] && WORKSPACE="$(basename "$PROJ")"
fi

echo "ifl-init — seeding bindings"
echo "  root:        $ROOT"
echo "  template:    $SRC"
echo "  detected:    project=$PROJECT_NAME  remote=$GIT_REMOTE  branch=$BASE_BRANCH"
echo "               system=$BUILD_SYSTEM  integration=$BUILD_INTEGRATION"
echo "               module-root=$MODULE_ROOT  workspace=$WORKSPACE"
echo "  dry:         $DRY"
echo

# ── Fill placeholders + write ────────────────────────────────────────────────

render() {
  # stdin → stdout with detected values substituted; unknowns left as {Placeholders}
  perl -pe '
    BEGIN {
      $pn=shift @ARGV; $ws=shift @ARGV; $bb=shift @ARGV; $gr=shift @ARGV;
      $gu=shift @ARGV; $bs=shift @ARGV; $bi=shift @ARGV; $mr=shift @ARGV;
    }
    s/\{ProjectName\}/$pn/g;
    s/\{Workspace\}/$ws/g;
    s/\{BaseBranch\}/$bb/g;
    s/\{GitRemote\}/$gr/g;
    s/\{GitRemoteURL\}/$gu/g;
    s/\{BuildSystem\}/$bs/g;
    s/\{BuildIntegration\}/$bi/g;
    s/\{ModuleRoot\}/$mr/g;
  ' -- "$PROJECT_NAME" "$WORKSPACE" "$BASE_BRANCH" "$GIT_REMOTE" "$GIT_URL" "$BUILD_SYSTEM" "$BUILD_INTEGRATION" "$MODULE_ROOT"
}

if [ "$DRY" = 1 ]; then
  echo "DRY  would write $DST_CLAUDE + $DST_AGENTS (twins)"
  echo "DRY  would write ${#CODEX_AGENT_SOURCES[@]} files under $DST_CODEX_AGENT_DIR"
  echo "DRY  remaining {Placeholders} to fill by hand or via /ifl-ios-standards:init:"
  render < "$SRC" | grep -oE '\{[A-Za-z]+\}' | sort -u | sed 's/^/       /'
  exit 0
fi

render < "$SRC" > "$DST_CLAUDE"
cp "$DST_CLAUDE" "$DST_AGENTS"
echo "  WROTE  CLAUDE.md + AGENTS.md (identical twins)"
write_codex_agents
echo
echo "Remaining {Placeholders} to fill (scheme, simulator, build/test, prefixes):"
grep -oE '\{[A-Za-z]+\}' "$DST_CLAUDE" | sort -u | sed 's/^/  /'
echo
echo "Next: fill them by hand, or run /ifl-ios-standards:init to detect + fill the rest interactively."
