#!/usr/bin/env bash
set -euo pipefail

# new-board.sh <Module> <Board> <type> [--root=PATH] [--module-root=PATH] [--dry-run]
#
# vinone Bazel fork of ifl-ios-pack bin/new-board.sh.
#
# Bazel note: this script emits ONLY .swift files under IO/{Board}/ and
# Sources/Microboards/{Board}/. The module's BUILD.bazel globs IO/**/*.swift and
# Sources/**/*.swift, so the new files are picked up automatically — NO per-board
# BUILD.bazel edit is required. (Run `bazel build //<root>/<Module>/...` after.)
#
# Types:
#   ui         — VIP stack (Board + Builder + Interactor + Presenter + ViewController + Protocols)
#   viewless   — Controller-backed (Board + Builder + Controller + Protocols)
#   flow       — Flow board only (Board)
#   blocktask  — Flow board only (Board)  (semantic alias; both shapes pure-Board)
#
# Emits under {ModuleRoot}/{Module}/:
#   IO/{Board}/{Board}IOInterface.swift            pub.mod.{Module}.{Board} + MainDestination + ioX factory
#   IO/{Board}/{Board}InOut.swift                  Input/Output/Command/Action types
#   IO/{Board}/ServiceMap+{Board}.swift            ioX on {Module}ServiceMap
#   Sources/Microboards/{Board}/{Board}BoardIOInterface.swift   mod{Board}Board alias
#   Sources/Microboards/{Board}/{Board}BoardInOut.swift         typealiases to IO types
#   Sources/Microboards/{Board}/{Board}Board.swift              Board class (type-specific shape)
#   Sources/Microboards/{Board}/ServiceMap+{Board}.swift        io{Board} on {Module}PluginsServiceMap
#   Sources/Microboards/{Board}/{Board}Builder.swift            (ui, viewless only)
#   Sources/Microboards/{Board}/{Board}Protocols.swift          (ui, viewless only)
#   Sources/Microboards/{Board}/{Board}Controller.swift         (viewless only)
#   Sources/Microboards/{Board}/{Board}Interactor.swift         (ui only)
#   Sources/Microboards/{Board}/{Board}Presenter.swift          (ui only)
#   Sources/Microboards/{Board}/{Board}ViewController.swift     (ui only)
#
# Resolves {ModuleRoot} like new-module.sh:
#   1. --module-root=PATH
#   2. `Module root` row in .claude/project/PROJECT_CONFIG.md
#   3. Default `Features`
#
# Refuses to overwrite an existing board directory.

usage() { sed -n '4,46p' "$0"; }

[ $# -ge 3 ] || { usage; exit 64; }

MODULE="$1"
BOARD="$2"
TYPE="$3"
shift 3

ROOT="$PWD"
MROOT=""
DRY=0

for v in MODULE BOARD; do
  val="${!v}"
  case "$val" in
    [A-Z]*) : ;;
    *) echo "new-board.sh: $v must start uppercase (got '$val')" >&2; exit 64 ;;
  esac
done

case "$TYPE" in
  ui|viewless|flow|blocktask) : ;;
  *) echo "new-board.sh: type must be ui|viewless|flow|blocktask (got '$TYPE')" >&2; exit 64 ;;
esac

for a in "$@"; do
  case "$a" in
    --root=*)         ROOT="${a#--root=}" ;;
    --module-root=*)  MROOT="${a#--module-root=}" ;;
    --dry-run)        DRY=1 ;;
    -h|--help)        usage; exit 0 ;;
    *) echo "new-board.sh: unknown arg '$a'" >&2; exit 64 ;;
  esac
done

[ -d "$ROOT" ] || { echo "new-board.sh: root '$ROOT' not a directory" >&2; exit 65; }
ROOT="$(cd "$ROOT" && pwd)"

resolve_module_root() {
  if [ -n "$MROOT" ]; then echo "$MROOT"; return; fi
  local cfg="$ROOT/.claude/project/PROJECT_CONFIG.md"
  if [ -f "$cfg" ]; then
    local hit
    hit="$(grep -E '^\|[[:space:]]*Module root[[:space:]]*\|' "$cfg" \
            | head -1 \
            | sed -E 's/.*\|[[:space:]]*`?([^`|]+)`?[[:space:]]*\|.*/\1/' \
            | sed -E 's/[[:space:]].*$//' \
            | sed -E 's/[[:space:]]+$//')"
    if [ -n "$hit" ]; then echo "${hit%/}"; return; fi
  fi
  echo "Features"
}

MROOT="$(resolve_module_root)"
MDIR="$ROOT/$MROOT/$MODULE"
BDIR="$MDIR/Sources/Microboards/$BOARD"
IDIR="$MDIR/IO/$BOARD"

[ -d "$MDIR" ] || { echo "new-board.sh: module dir '$MDIR' missing — run new-module.sh $MODULE first" >&2; exit 1; }

if [ -e "$IDIR" ] || [ -e "$BDIR" ]; then
  echo "new-board.sh: board destination exists" >&2
  [ -e "$IDIR" ] && echo "  $IDIR" >&2
  [ -e "$BDIR" ] && echo "  $BDIR" >&2
  exit 1
fi

YEAR_DATE="$(date +%Y-%m-%d)"

emit() {
  local path="$1"; shift
  local content="$1"
  if [ "$DRY" = 1 ]; then
    echo "DRY  write $path  (${#content} bytes)"
    return
  fi
  mkdir -p "$(dirname "$path")"
  printf '%s\n' "$content" > "$path"
  echo "  WRITE  ${path#$ROOT/}"
}

echo "new-board.sh — scaffolding $BOARD ($TYPE) in $MODULE"
echo "  root:        $ROOT"
echo "  module:      $MDIR"
echo "  io-dir:      $IDIR"
echo "  src-dir:     $BDIR"
echo "  dry:         $DRY"
echo

# ── IO files ────────────────────────────────────────────────────────────────

emit "$IDIR/${BOARD}IOInterface.swift" "// Created on $YEAR_DATE by ifl-scaffold new-board.sh

import Boardy
import Foundation

public extension BoardID {
    static let pub${BOARD}: BoardID = \"pub.mod.${MODULE}.${BOARD}\"
}

public typealias ${BOARD}MainDestination = MainboardGenericDestination<
    ${BOARD}Input,
    ${BOARD}Output,
    ${BOARD}Command,
    ${BOARD}Action
>

public extension MotherboardType where Self: FlowManageable {
    func io${BOARD}(_ identifier: BoardID = .pub${BOARD}) -> ${BOARD}MainDestination {
        ${BOARD}MainDestination(destinationID: identifier, mainboard: self)
    }
}"

emit "$IDIR/${BOARD}InOut.swift" "// Created on $YEAR_DATE by ifl-scaffold new-board.sh

import Boardy
import Foundation

public struct ${BOARD}Input {
    public init() {}
}

public typealias ${BOARD}Output = Void
public typealias ${BOARD}Command = Void
public enum ${BOARD}Action: BoardFlowAction {}"

emit "$IDIR/ServiceMap+${BOARD}.swift" "// Created on $YEAR_DATE by ifl-scaffold new-board.sh

import Boardy
import Foundation

public extension ${MODULE}ServiceMap {
    var io${BOARD}: ${BOARD}MainDestination {
        mainboard.io${BOARD}()
    }
}"

# ── Sources: ServiceMap+ + IOInterface + InOut (all types) ──────────────────

emit "$BDIR/${BOARD}BoardIOInterface.swift" "// Created on $YEAR_DATE by ifl-scaffold new-board.sh

import Boardy
import Foundation
import ${MODULE}

extension BoardID {
    static let mod${BOARD}Board: BoardID = .pub${BOARD}
}"

emit "$BDIR/${BOARD}BoardInOut.swift" "// Created on $YEAR_DATE by ifl-scaffold new-board.sh

import ${MODULE}

typealias ${BOARD}BoardInput = ${BOARD}Input
typealias ${BOARD}BoardOutput = ${BOARD}Output
typealias ${BOARD}BoardCommand = ${BOARD}Command
typealias ${BOARD}BoardAction = ${BOARD}Action"

emit "$BDIR/ServiceMap+${BOARD}.swift" "// Created on $YEAR_DATE by ifl-scaffold new-board.sh

import Boardy
import Foundation
import ${MODULE}

extension ${MODULE}PluginsServiceMap {
    var io${BOARD}: ${BOARD}MainDestination { mainboard.io${BOARD}() }
}"

# ── Sources: Board.swift (type-specific) ────────────────────────────────────

case "$TYPE" in
ui)
  emit "$BDIR/${BOARD}Board.swift" "// Created on $YEAR_DATE by ifl-scaffold new-board.sh

import Boardy
import Foundation
import ${MODULE}
import SiFUtilities
import UIKit

final class ${BOARD}Board: ModernContinuableBoard, GuaranteedBoard,
    GuaranteedOutputSendingBoard, GuaranteedActionSendingBoard, GuaranteedCommandBoard {

    typealias InputType = ${BOARD}BoardInput
    typealias OutputType = ${BOARD}BoardOutput
    typealias FlowActionType = ${BOARD}BoardAction
    typealias CommandType = ${BOARD}BoardCommand

    private let builder: ${BOARD}Buildable

    init(identifier: BoardID, builder: ${BOARD}Buildable, producer: ActivatableBoardProducer) {
        self.builder = builder
        super.init(identifier: identifier, boardProducer: producer)
    }

    func activate(withGuaranteedInput input: InputType) {
        let component = builder.build(withDelegate: self, input: input)
        attachObject(component.controller)
        // TODO: present component.userInterface via SiFUtilities show(_:) — see MICROBOARD_UI.md
    }

    func activationBarrier(withGuaranteedInput _: InputType) -> ActivationBarrier? { nil }
    func interact(guaranteedCommand _: CommandType) {}
}

extension ${BOARD}Board: ${BOARD}Delegate {
    // TODO: implement ${BOARD}ActionDelegate + ${BOARD}ControlDelegate
}"

  emit "$BDIR/${BOARD}Builder.swift" "// Created on $YEAR_DATE by ifl-scaffold new-board.sh

import ${MODULE}
import UIKit

struct ${BOARD}Builder: ${BOARD}Buildable {
    func build(withDelegate delegate: ${BOARD}Delegate?, input: ${BOARD}BoardInput) -> ${BOARD}Interface {
        let viewController = ${BOARD}ViewController()
        let presenter = ${BOARD}Presenter()
        presenter.view = viewController

        let interactor = ${BOARD}Interactor(presenter: presenter, input: input)
        interactor.delegate = delegate

        viewController.actionDelegate = delegate
        viewController.interactor = interactor

        return ${BOARD}Interface(
            userInterface: viewController,
            controller: interactor
        )
    }
}"

  emit "$BDIR/${BOARD}Interactor.swift" "// Created on $YEAR_DATE by ifl-scaffold new-board.sh

import Foundation
import ${MODULE}

protocol ${BOARD}Presentable: AnyObject {
    // TODO: presenter calls — see EXAMPLES specs
}

final class ${BOARD}Interactor {
    weak var delegate: ${BOARD}ControlDelegate!
    private let presenter: ${BOARD}Presentable
    private let input: ${BOARD}BoardInput

    init(presenter: ${BOARD}Presentable, input: ${BOARD}BoardInput) {
        self.presenter = presenter
        self.input = input
    }
}

extension ${BOARD}Interactor: ${BOARD}Controllable, ${BOARD}Interactable {
    // TODO: implement ${BOARD}Interactable (VC → interactor) + ${BOARD}Controllable (Board → interactor)
}"

  emit "$BDIR/${BOARD}Presenter.swift" "// Created on $YEAR_DATE by ifl-scaffold new-board.sh

import Foundation
import ${MODULE}

protocol ${BOARD}Viewable: AnyObject {
    // TODO: view-state calls — see EXAMPLES specs
}

final class ${BOARD}Presenter {
    weak var view: ${BOARD}Viewable!
}

extension ${BOARD}Presenter: ${BOARD}Presentable {
    // TODO: implement ${BOARD}Presentable
}"

  emit "$BDIR/${BOARD}ViewController.swift" "// Created on $YEAR_DATE by ifl-scaffold new-board.sh

import ${MODULE}
import UIKit

final class ${BOARD}ViewController: UIViewController, ${BOARD}UserInterface {

    var interactor: ${BOARD}Interactable!
    weak var actionDelegate: ${BOARD}ActionDelegate?

    override func viewDidLoad() {
        super.viewDidLoad()
        // TODO: setup
        interactor.didBecomeActive()
    }
}

extension ${BOARD}ViewController: ${BOARD}Viewable {
    // TODO: implement ${BOARD}Viewable render methods
}"

  emit "$BDIR/${BOARD}Protocols.swift" "// Created on $YEAR_DATE by ifl-scaffold new-board.sh

import ${MODULE}
import UIKit

// MARK: - Inward (Board → Interactor)
protocol ${BOARD}Controllable: AnyObject {}

// MARK: - Inward (VC → Interactor)
protocol ${BOARD}Interactable: AnyObject {
    func didBecomeActive()
}

// MARK: - Outward (VC → Board)
protocol ${BOARD}ActionDelegate: AnyObject {}

// MARK: - Outward (Interactor → Board)
protocol ${BOARD}ControlDelegate: AnyObject {}

protocol ${BOARD}Delegate: ${BOARD}ActionDelegate, ${BOARD}ControlDelegate {}

// MARK: - View interface
protocol ${BOARD}UserInterface: UIViewController {}

// MARK: - Interface
struct ${BOARD}Interface {
    let userInterface: ${BOARD}UserInterface
    let controller: ${BOARD}Controllable
}

// MARK: - Builder
protocol ${BOARD}Buildable {
    func build(withDelegate delegate: ${BOARD}Delegate?, input: ${BOARD}BoardInput) -> ${BOARD}Interface
}"
  ;;

viewless)
  emit "$BDIR/${BOARD}Board.swift" "// Created on $YEAR_DATE by ifl-scaffold new-board.sh

import Boardy
import Foundation
import ${MODULE}

final class ${BOARD}Board: ModernContinuableBoard, GuaranteedBoard,
    GuaranteedOutputSendingBoard, GuaranteedActionSendingBoard, GuaranteedCommandBoard {

    typealias InputType = ${BOARD}BoardInput
    typealias OutputType = ${BOARD}BoardOutput
    typealias FlowActionType = ${BOARD}BoardAction
    typealias CommandType = ${BOARD}BoardCommand

    private let builder: ${BOARD}Buildable

    init(identifier: BoardID, builder: ${BOARD}Buildable, producer: ActivatableBoardProducer) {
        self.builder = builder
        super.init(identifier: identifier, boardProducer: producer)
    }

    func activate(withGuaranteedInput input: InputType) {
        let component = builder.build(withDelegate: self, input: input)
        attachObject(component.controller)
        component.controller.start()
    }

    func activationBarrier(withGuaranteedInput _: InputType) -> ActivationBarrier? { nil }
    func interact(guaranteedCommand _: CommandType) {}
}

extension ${BOARD}Board: ${BOARD}Delegate {
    // TODO: implement ${BOARD}ControlDelegate — see EXAMPLES_VIEWLESS_BOARD.md
}"

  emit "$BDIR/${BOARD}Builder.swift" "// Created on $YEAR_DATE by ifl-scaffold new-board.sh

import Foundation

struct ${BOARD}Builder: ${BOARD}Buildable {
    func build(withDelegate delegate: ${BOARD}Delegate?,
               input: ${BOARD}BoardInput) -> ${BOARD}Interface {
        let controller = ${BOARD}Controller(input: input)
        controller.delegate = delegate
        return ${BOARD}Interface(controller: controller)
    }
}"

  emit "$BDIR/${BOARD}Controller.swift" "// Created on $YEAR_DATE by ifl-scaffold new-board.sh

import Foundation

final class ${BOARD}Controller: NSObject {
    weak var delegate: ${BOARD}ControlDelegate?
    private let input: ${BOARD}BoardInput

    init(input: ${BOARD}BoardInput) {
        self.input = input
    }
}

extension ${BOARD}Controller: ${BOARD}Controllable {
    func start() {
        // TODO: kick off work; call delegate?.* to escalate to Board
    }
}"

  emit "$BDIR/${BOARD}Protocols.swift" "// Created on $YEAR_DATE by ifl-scaffold new-board.sh

import Foundation

protocol ${BOARD}Controllable: AnyObject {
    func start()
}

protocol ${BOARD}ControlDelegate: AnyObject {
    // TODO: controller → board callbacks
}

protocol ${BOARD}Delegate: ${BOARD}ControlDelegate {}

struct ${BOARD}Interface {
    let controller: ${BOARD}Controllable
}

protocol ${BOARD}Buildable {
    func build(withDelegate delegate: ${BOARD}Delegate?,
               input: ${BOARD}BoardInput) -> ${BOARD}Interface
}"
  ;;

flow|blocktask)
  emit "$BDIR/${BOARD}Board.swift" "// Created on $YEAR_DATE by ifl-scaffold new-board.sh

import Boardy
import Foundation
import ${MODULE}

final class ${BOARD}Board: ModernContinuableBoard, GuaranteedBoard,
    GuaranteedOutputSendingBoard, GuaranteedActionSendingBoard, GuaranteedCommandBoard {

    typealias InputType = ${BOARD}BoardInput
    typealias OutputType = ${BOARD}BoardOutput
    typealias FlowActionType = ${BOARD}BoardAction
    typealias CommandType = ${BOARD}BoardCommand

    init(identifier: BoardID, producer: ActivatableBoardProducer) {
        super.init(identifier: identifier, boardProducer: producer)
        registerFlows()
    }

    func activate(withGuaranteedInput input: InputType) {
        // TODO: orchestrate child boards via motherboard.serviceMap.mod${MODULE}Plugins.io*
    }

    func activationBarrier(withGuaranteedInput _: InputType) -> ActivationBarrier? { nil }
    func interact(guaranteedCommand _: CommandType) {}
}

private extension ${BOARD}Board {
    func registerFlows() {
        // TODO: addTarget(self) callbacks on child board flows — see EXAMPLES_NONUI_BOARDS.md
    }
}"
  ;;
esac

if [ "$DRY" != 1 ]; then
  echo
  echo "Done. Next steps:"
  echo "  1. Register ${BOARD}Board in ${MODULE}ModulePlugin.swift (ServiceType case + build())."
  echo "  2. Fill in TODO markers — see .ai/specs EXAMPLES_*.md."
  echo "  3. Bazel auto-globs the new files — no BUILD.bazel edit needed. If ${BOARD} imports a"
  echo "     new cross-module IO target, add it to PLUGINS_DEPENDENCIES in $MROOT/$MODULE/BUILD.bazel."
  echo "  4. Verify:  bazel build //$MROOT/$MODULE:${MODULE}Plugins"
fi
