#!/usr/bin/env bash
set -euo pipefail

# ifl-new-board <Module> <Board> <ui|swiftui|viewless|flow|blocktask>
#   [--root=PATH] [--module-root=PATH] [--dry-run]
#
# Emits Boardy IO and source skeletons only. The consuming repository owns build-system wiring,
# concrete dependencies, tests, presentation copy, and product behavior. Existing destinations are
# never overwritten.

usage() { sed -n '4,12p' "$0"; }

[ $# -ge 3 ] || { usage; exit 64; }

MODULE="$1"
BOARD="$2"
TYPE="$3"
shift 3

ROOT="$PWD"
MROOT=""
DRY=0

for value in "$MODULE" "$BOARD"; do
  if ! [[ "$value" =~ ^[A-Z][A-Za-z0-9]*$ ]]; then
    echo "ifl-new-board: module and board names must match [A-Z][A-Za-z0-9]* (got '$value')" >&2
    exit 64
  fi
done

case "$TYPE" in
  ui|swiftui|viewless|flow|blocktask) : ;;
  *) echo "ifl-new-board: type must be ui|swiftui|viewless|flow|blocktask (got '$TYPE')" >&2; exit 64 ;;
esac

for argument in "$@"; do
  case "$argument" in
    --root=*)        ROOT="${argument#--root=}" ;;
    --module-root=*) MROOT="${argument#--module-root=}" ;;
    --dry-run)       DRY=1 ;;
    -h|--help)       usage; exit 0 ;;
    *) echo "ifl-new-board: unknown argument '$argument'" >&2; exit 64 ;;
  esac
done

[ -d "$ROOT" ] || { echo "ifl-new-board: root '$ROOT' is not a directory" >&2; exit 65; }
ROOT="$(cd "$ROOT" && pwd)"

module_root_from() {
  local file="$1"
  [ -f "$file" ] || return 0
  grep -E '^\|[[:space:]]*Module root[[:space:]]*\|' "$file" \
    | head -1 \
    | sed -E 's/.*\|[[:space:]]*`?([^`|]+)`?[[:space:]]*\|.*/\1/' \
    | sed -E 's/[[:space:]]+$//' \
    || true
}

resolve_module_root() {
  if [ -n "$MROOT" ]; then
    printf '%s\n' "$MROOT"
    return
  fi

  local file value
  for file in \
    "$ROOT/CLAUDE.md" \
    "$ROOT/AGENTS.md" \
    "$ROOT/.claude/project/PROJECT_CONFIG.md"; do
    value="$(module_root_from "$file")"
    if [ -n "$value" ] && [[ "$value" != \{* ]]; then
      printf '%s\n' "${value%/}"
      return
    fi
  done

  echo "ifl-new-board: module root is not configured; pass --module-root=PATH or set the Module root row in CLAUDE.md/AGENTS.md" >&2
  exit 64
}

MROOT="$(resolve_module_root)"
if ! [[ "$MROOT" =~ ^[A-Za-z0-9._/-]+$ ]]; then
  echo "ifl-new-board: module root must be a repository-relative path token (got '$MROOT')" >&2
  exit 64
fi
case "$MROOT" in
  ..|../*|*/..|*/../*|./*|*/.|*/./*) echo "ifl-new-board: module root must not contain traversal components (got '$MROOT')" >&2; exit 64 ;;
esac
case "$MROOT" in
  /*) echo "ifl-new-board: module root must be repository-relative (got '$MROOT')" >&2; exit 64 ;;
esac

MDIR="$ROOT/$MROOT/$MODULE"
BDIR="$MDIR/Sources/Microboards/$BOARD"
IDIR="$MDIR/IO/$BOARD"

[ -d "$MDIR" ] || { echo "ifl-new-board: module directory '$MDIR' is missing; run ifl-new-module first" >&2; exit 1; }
if [ -e "$IDIR" ] || [ -e "$BDIR" ]; then
  echo "ifl-new-board: board destination exists" >&2
  [ -e "$IDIR" ] && echo "  $IDIR" >&2
  [ -e "$BDIR" ] && echo "  $BDIR" >&2
  exit 1
fi

CREATED_ON="$(date +%Y-%m-%d)"

emit() {
  local path="$1"
  local content="$2"
  if [ "$DRY" = 1 ]; then
    echo "DRY  write $path  (${#content} bytes)"
    return
  fi
  mkdir -p "$(dirname "$path")"
  printf '%s\n' "$content" > "$path"
  echo "  WRITE  ${path#$ROOT/}"
}

echo "ifl-new-board — scaffolding $BOARD ($TYPE) in $MODULE"
echo "  root:        $ROOT"
echo "  module-root: $MROOT"
echo "  io:          $IDIR"
echo "  source:      $BDIR"
echo "  dry:         $DRY"
echo

DESTINATION_INPUT="${BOARD}Input"
if [ "$TYPE" = "blocktask" ]; then
  DESTINATION_INPUT="${BOARD}Parameter"
fi

emit "$IDIR/${BOARD}IOInterface.swift" "// Created on $CREATED_ON by ifl-new-board

import Boardy

public extension BoardID {
    static let pub${BOARD}: BoardID = \"pub.mod.${MODULE}.${BOARD}\"
}

public typealias ${BOARD}MainDestination = MainboardGenericDestination<
    ${DESTINATION_INPUT},
    ${BOARD}Output,
    ${BOARD}Command,
    ${BOARD}Action
>

public extension MotherboardType where Self: FlowManageable {
    func io${BOARD}(_ identifier: BoardID = .pub${BOARD}) -> ${BOARD}MainDestination {
        ${BOARD}MainDestination(destinationID: identifier, mainboard: self)
    }
}"

if [ "$TYPE" = "viewless" ]; then
  emit "$IDIR/${BOARD}InOut.swift" "// Created on $CREATED_ON by ifl-new-board

import Boardy
import UIKit

public struct ${BOARD}Input {
    public weak var context: UIViewController?

    public init(context: UIViewController? = nil) {
        self.context = context
    }
}

public typealias ${BOARD}Output = Void
public typealias ${BOARD}Command = Void
public enum ${BOARD}Action: BoardFlowAction {}"
else
  PARAMETER_ALIAS=""
  if [ "$TYPE" = "blocktask" ]; then
    PARAMETER_ALIAS=$'\npublic typealias '"${BOARD}"$'Parameter = BlockTaskParameter<'"${BOARD}"$'Input, '"${BOARD}"$'Output>\n'
  fi
  emit "$IDIR/${BOARD}InOut.swift" "// Created on $CREATED_ON by ifl-new-board

import Boardy

public struct ${BOARD}Input {
    public init() {}
}
${PARAMETER_ALIAS}
public typealias ${BOARD}Output = Void
public typealias ${BOARD}Command = Void
public enum ${BOARD}Action: BoardFlowAction {}"
fi

emit "$IDIR/ServiceMap+${BOARD}.swift" "// Created on $CREATED_ON by ifl-new-board

import Boardy

public extension ${MODULE}ServiceMap {
    var io${BOARD}: ${BOARD}MainDestination { mainboard.io${BOARD}() }
}"

emit "$BDIR/${BOARD}BoardIOInterface.swift" "// Created on $CREATED_ON by ifl-new-board

import Boardy
import $MODULE

extension BoardID {
    static let mod${BOARD}Board: BoardID = .pub${BOARD}
}"

INTERNAL_PARAMETER_ALIAS=""
if [ "$TYPE" = "blocktask" ]; then
  INTERNAL_PARAMETER_ALIAS=$'\ntypealias '"${BOARD}"$'BoardParameter = '"${BOARD}"$'Parameter'
fi
emit "$BDIR/${BOARD}BoardInOut.swift" "// Created on $CREATED_ON by ifl-new-board

import $MODULE

typealias ${BOARD}BoardInput = ${BOARD}Input
typealias ${BOARD}BoardOutput = ${BOARD}Output
typealias ${BOARD}BoardCommand = ${BOARD}Command
typealias ${BOARD}BoardAction = ${BOARD}Action${INTERNAL_PARAMETER_ALIAS}"

emit "$BDIR/ServiceMap+${BOARD}.swift" "// Created on $CREATED_ON by ifl-new-board

import Boardy
import $MODULE

extension ${MODULE}PluginsServiceMap {
    var io${BOARD}: ${BOARD}MainDestination { mainboard.io${BOARD}() }
}"

case "$TYPE" in
ui|swiftui)
  emit "$BDIR/${BOARD}Board.swift" "// Created on $CREATED_ON by ifl-new-board

import Boardy
import $MODULE
import SiFUtilities
import UIKit

final class ${BOARD}Board: ModernContinuableBoard, GuaranteedBoard,
    GuaranteedOutputSendingBoard, GuaranteedActionSendingBoard, GuaranteedCommandBoard {

    typealias InputType = ${BOARD}BoardInput
    typealias OutputType = ${BOARD}BoardOutput
    typealias FlowActionType = ${BOARD}BoardAction
    typealias CommandType = ${BOARD}BoardCommand

    private let builder: ${BOARD}Buildable

    init(identifier: BoardID, builder: ${BOARD}Buildable, producer: ActivatableBoardProducer) {
        self.builder = builder
        super.init(identifier: identifier, boardProducer: producer)
        registerFlows()
    }

    func activate(withGuaranteedInput input: InputType) {
        MainActor.assumeIsolated {
            let component = builder.build(withDelegate: self, input: input)
            watch(content: component.controller)
            motherboard.putIntoContext(component.userInterface)
            rootViewController.show(component.userInterface)
        }
    }

    func activationBarrier(withGuaranteedInput _: InputType) -> ActivationBarrier? { nil }
    func interact(guaranteedCommand _: CommandType) {}
}

extension ${BOARD}Board: ${BOARD}Delegate {
    // TODO: implement typed ActionDelegate and ControlDelegate outcomes.
}

private extension ${BOARD}Board {
    func registerFlows() {
        // TODO: register child flows here. Never register them from activate().
    }
}"

  emit "$BDIR/${BOARD}Interactor.swift" "// Created on $CREATED_ON by ifl-new-board

import $MODULE

@MainActor
protocol ${BOARD}Presentable: AnyObject {
    func present(_ state: ${BOARD}ViewState)
}

final class ${BOARD}Interactor {
    weak var delegate: ${BOARD}ControlDelegate?
    private let presenter: ${BOARD}Presentable
    private let input: ${BOARD}BoardInput

    init(presenter: ${BOARD}Presentable, input: ${BOARD}BoardInput) {
        self.presenter = presenter
        self.input = input
    }
}

extension ${BOARD}Interactor: ${BOARD}Controllable, ${BOARD}Interactable {
    func didBecomeActive() {
        // TODO: execute use cases and send domain results to the Presenter.
    }
}"

  emit "$BDIR/${BOARD}Presenter.swift" "// Created on $CREATED_ON by ifl-new-board

import Foundation

struct ${BOARD}ViewState: Equatable {
    enum Phase: Equatable { case idle }
    let phase: Phase

    static let idle = Self(phase: .idle)
}

@MainActor
protocol ${BOARD}Viewable: AnyObject {
    func render(_ state: ${BOARD}ViewState)
}

@MainActor
final class ${BOARD}Presenter {
    weak var view: ${BOARD}Viewable?
}

extension ${BOARD}Presenter: ${BOARD}Presentable {
    func present(_ state: ${BOARD}ViewState) {
        view?.render(state)
    }
}"

  emit "$BDIR/${BOARD}Protocols.swift" "// Created on $CREATED_ON by ifl-new-board

import $MODULE
import UIKit

protocol ${BOARD}Controllable: AnyObject {}

protocol ${BOARD}Interactable: AnyObject {
    func didBecomeActive()
}

protocol ${BOARD}ActionDelegate: AnyObject {}
protocol ${BOARD}ControlDelegate: AnyObject {}
protocol ${BOARD}Delegate: ${BOARD}ActionDelegate, ${BOARD}ControlDelegate {}

struct ${BOARD}Interface {
    let userInterface: UIViewController
    let controller: ${BOARD}Controllable
}

@MainActor
protocol ${BOARD}Buildable {
    func build(withDelegate delegate: ${BOARD}Delegate?, input: ${BOARD}BoardInput) -> ${BOARD}Interface
}"

  if [ "$TYPE" = "ui" ]; then
    emit "$BDIR/${BOARD}Builder.swift" "// Created on $CREATED_ON by ifl-new-board

import $MODULE

@MainActor
struct ${BOARD}Builder: ${BOARD}Buildable {
    func build(withDelegate delegate: ${BOARD}Delegate?, input: ${BOARD}BoardInput) -> ${BOARD}Interface {
        let viewController = ${BOARD}ViewController()
        let presenter = ${BOARD}Presenter()
        let interactor = ${BOARD}Interactor(presenter: presenter, input: input)

        presenter.view = viewController
        interactor.delegate = delegate
        viewController.actionDelegate = delegate
        viewController.interactor = interactor

        return ${BOARD}Interface(userInterface: viewController, controller: interactor)
    }
}"

    emit "$BDIR/${BOARD}ViewController.swift" "// Created on $CREATED_ON by ifl-new-board

import $MODULE
import UIKit

final class ${BOARD}ViewController: UIViewController {
    var interactor: ${BOARD}Interactable!
    weak var actionDelegate: ${BOARD}ActionDelegate?

    override func viewDidLoad() {
        super.viewDidLoad()
        interactor.didBecomeActive()
    }
}

extension ${BOARD}ViewController: ${BOARD}Viewable {
    func render(_ state: ${BOARD}ViewState) {
        // Render display-ready state and framework-local UX mechanics only.
    }
}"
  else
    emit "$BDIR/${BOARD}Builder.swift" "// Created on $CREATED_ON by ifl-new-board

import $MODULE
import SwiftUI

@MainActor
struct ${BOARD}Builder: ${BOARD}Buildable {
    func build(withDelegate delegate: ${BOARD}Delegate?, input: ${BOARD}BoardInput) -> ${BOARD}Interface {
        let presenter = ${BOARD}Presenter()
        let interactor = ${BOARD}Interactor(presenter: presenter, input: input)
        let store = ${BOARD}PresentationStore()

        presenter.view = store
        interactor.delegate = delegate

        let host = ${BOARD}HostingController(store: store) { [weak interactor] in
            interactor?.didBecomeActive()
        }
        return ${BOARD}Interface(userInterface: host, controller: interactor)
    }
}"

    emit "$BDIR/${BOARD}PresentationStore.swift" "// Created on $CREATED_ON by ifl-new-board

import Combine

@MainActor
final class ${BOARD}PresentationStore: ObservableObject, ${BOARD}Viewable {
    @Published private(set) var state: ${BOARD}ViewState = .idle

    func render(_ state: ${BOARD}ViewState) {
        self.state = state
    }
}"

    emit "$BDIR/${BOARD}HostingController.swift" "// Created on $CREATED_ON by ifl-new-board

import SwiftUI
import UIKit

@MainActor
final class ${BOARD}HostingController: UIHostingController<${BOARD}View> {
    private let activate: () -> Void
    private var hasActivated = false

    init(store: ${BOARD}PresentationStore, activate: @escaping () -> Void) {
        self.activate = activate
        super.init(rootView: ${BOARD}View(store: store))
    }

    @available(*, unavailable)
    required init?(coder aDecoder: NSCoder) {
        fatalError(\"init(coder:) has not been implemented\")
    }

    override func viewDidLoad() {
        super.viewDidLoad()
        guard !hasActivated else { return }
        hasActivated = true
        activate()
    }
}"

    emit "$BDIR/${BOARD}View.swift" "// Created on $CREATED_ON by ifl-new-board

import SwiftUI

struct ${BOARD}View: View {
    @ObservedObject var store: ${BOARD}PresentationStore

    var body: some View {
        content
    }

    @ViewBuilder
    private var content: some View {
        switch store.state.phase {
        case .idle:
            EmptyView()
        }
    }
}"
  fi
  ;;

viewless)
  emit "$BDIR/${BOARD}Board.swift" "// Created on $CREATED_ON by ifl-new-board

import Boardy
import $MODULE

final class ${BOARD}Board: ModernContinuableBoard, GuaranteedBoard,
    GuaranteedOutputSendingBoard, GuaranteedActionSendingBoard, GuaranteedCommandBoard {

    typealias InputType = ${BOARD}BoardInput
    typealias OutputType = ${BOARD}BoardOutput
    typealias FlowActionType = ${BOARD}BoardAction
    typealias CommandType = ${BOARD}BoardCommand

    private let builder: ${BOARD}Buildable

    init(identifier: BoardID, builder: ${BOARD}Buildable, producer: ActivatableBoardProducer) {
        self.builder = builder
        super.init(identifier: identifier, boardProducer: producer)
        registerFlows()
    }

    func activate(withGuaranteedInput input: InputType) {
        let component = builder.build(withDelegate: self, input: input)
        if let context = input.context {
            attachObject(component.controller, context: context)
        } else {
            attachObject(component.controller, context: rootViewController)
        }
        component.controller.start()
    }

    func activationBarrier(withGuaranteedInput _: InputType) -> ActivationBarrier? { nil }
    func interact(guaranteedCommand _: CommandType) {}
}

extension ${BOARD}Board: ${BOARD}Delegate {
    // TODO: implement typed controller outcomes and release the activation exactly once.
}

private extension ${BOARD}Board {
    func registerFlows() {
        // TODO: register child flows here. Board-to-controller delivery uses buses, not retrieval.
    }
}"

  emit "$BDIR/${BOARD}Builder.swift" "// Created on $CREATED_ON by ifl-new-board

struct ${BOARD}Builder: ${BOARD}Buildable {
    func build(withDelegate delegate: ${BOARD}Delegate?, input: ${BOARD}BoardInput) -> ${BOARD}Interface {
        let controller = ${BOARD}Controller(input: input)
        controller.delegate = delegate
        return ${BOARD}Interface(controller: controller)
    }
}"

  emit "$BDIR/${BOARD}Controller.swift" "// Created on $CREATED_ON by ifl-new-board

import Foundation

final class ${BOARD}Controller: NSObject {
    weak var delegate: ${BOARD}ControlDelegate?
    private let input: ${BOARD}BoardInput

    init(input: ${BOARD}BoardInput) {
        self.input = input
    }
}

extension ${BOARD}Controller: ${BOARD}Controllable {
    func start() {
        // TODO: start controller-owned work and report typed outcomes through delegate.
    }
}"

  emit "$BDIR/${BOARD}Protocols.swift" "// Created on $CREATED_ON by ifl-new-board

import $MODULE

protocol ${BOARD}Controllable: AnyObject {
    func start()
}

protocol ${BOARD}ControlDelegate: AnyObject {}
protocol ${BOARD}Delegate: ${BOARD}ControlDelegate {}

struct ${BOARD}Interface {
    let controller: ${BOARD}Controllable
}

protocol ${BOARD}Buildable {
    func build(withDelegate delegate: ${BOARD}Delegate?, input: ${BOARD}BoardInput) -> ${BOARD}Interface
}"
  ;;

flow)
  emit "$BDIR/${BOARD}Board.swift" "// Created on $CREATED_ON by ifl-new-board

import Boardy
import $MODULE

final class ${BOARD}Board: ModernContinuableBoard, GuaranteedBoard,
    GuaranteedOutputSendingBoard, GuaranteedActionSendingBoard, GuaranteedCommandBoard {

    typealias InputType = ${BOARD}BoardInput
    typealias OutputType = ${BOARD}BoardOutput
    typealias FlowActionType = ${BOARD}BoardAction
    typealias CommandType = ${BOARD}BoardCommand

    init(identifier: BoardID, producer: ActivatableBoardProducer) {
        super.init(identifier: identifier, boardProducer: producer)
        registerFlows()
    }

    func activate(withGuaranteedInput _: InputType) {
        // TODO: orchestrate child boards without storing activation state on this Board.
    }

    func activationBarrier(withGuaranteedInput _: InputType) -> ActivationBarrier? { nil }
    func interact(guaranteedCommand _: CommandType) {}
}

private extension ${BOARD}Board {
    func registerFlows() {
        // TODO: register child flow handlers once.
    }
}"
  ;;

blocktask)
  emit "$BDIR/${BOARD}BoardFactory.swift" "// Created on $CREATED_ON by ifl-new-board

import Boardy
import $MODULE

enum ${BOARD}BoardFactory {
    static func make(identifier: BoardID, executingType: ExecutingType = .concurrent) -> ActivatableBoard {
        BlockTaskBoard<${BOARD}BoardInput, ${BOARD}BoardOutput>(
            identifier: identifier,
            executingType: executingType
        ) { _, _, _ in
            preconditionFailure(\"Implement ${BOARD} BlockTask execution and complete on MainActor\")
        }
    }
}"
  ;;
esac

if [ "$DRY" != 1 ]; then
  echo
  echo "Done. Next steps:"
  echo "  1. Create or complete ${MODULE}ModulePlugin and register $BOARD using BoardID.pub${BOARD}."
  echo "  2. Replace TODO/fail-fast placeholders with project-owned dependencies and behavior."
  echo "  3. Add the generated sources to the consuming repository's build/package configuration."
  echo "  4. Add meaningful executable tests for changed behavior and run one owned native signal."
fi
