{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:ifl:standards:schema:requirements:v1",
  "title": "IFL Requirements Registry v1",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "non_blank": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!\\s)(?!.*\\s$)[^\\u0000-\\u001F\\u007F-\\u009F]+$"
    },
    "requirement_id": {
      "type": "string",
      "pattern": "^(?:(?:REQ|ENT)-[A-Z0-9]+(?:-[A-Z0-9]+)*|P[0-3]-[1-9][0-9]*)$"
    },
    "requirement": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "schema_version": { "const": 1 },
        "id": { "$ref": "#/$defs/requirement_id" },
        "accountable_owner_role_id": { "$ref": "#/$defs/non_blank" },
        "status": {
          "type": "string",
          "enum": ["planned", "in_progress", "completed", "deferred", "blocked"]
        }
      },
      "required": ["schema_version", "id", "accountable_owner_role_id", "status"]
    }
  },
  "properties": {
    "schema_version": { "const": 1 },
    "requirements": {
      "type": "array",
      "items": { "$ref": "#/$defs/requirement" },
      "minItems": 1,
      "uniqueItems": true
    }
  },
  "required": ["schema_version", "requirements"]
}
